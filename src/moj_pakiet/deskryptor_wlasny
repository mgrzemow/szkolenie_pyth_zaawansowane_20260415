class DeskryptorZliczajacy:
    def __init__(self, atr_name=None) -> None:
        self._atr_name = atr_name
        self._licznik_zapisow = collections.defaultdict(int)
        self._licznik_odczytow = collections.defaultdict(int)

    # wywołuje się jeżeli użyję deskrypotora w klasie i przekaże do deskryptora nazwe atrybutu
    def __set_name__(self, owner, name):
        if not self._atr_name:
            self._atr_name = name
        self._atr_name = "_" + name

    def __get__(self, instance, owner):
        if instance is not None:
            self._licznik_odczytow[id(instance)] += 1
            print("odczytow: ", self._licznik_odczytow)
            return getattr(instance, self._atr_name)
        else:
            return self

    def __set__(self, instance, value):
        setattr(instance, self._atr_name, value)
        self._licznik_zapisow[id(instance)] += 1
        print("oczytow: ", self._licznik_zapisow)

    def get_read_count(self, instance):
        return self._licznik_odczytow[id(instance)]

    def get_write_count(self, instance):
        return self._licznik_zapisow[id(instance)]


class A:
    atr1 = DeskryptorZliczajacy()

    def __init__(self, atr1) -> None:
